  "_meta": {
    "purpose": "Realistic placeholder data for Claude Design. Drop these into mockups instead of inventing data shapes. Every field matches the SpreadPnl / Spread / SpreadLeg interface in src/types/canonical.ts. Numbers derive from the worked examples in the arbitrage domain brief, kept internally consistent under the spread_pnl view's formulas.",
    "_formulas": {
      "realized_apr": "(net_pnl_quote / capital_deployed_usd) * (365 / days_held)",
      "bps_captured_net": "(net_pnl_quote / capital_deployed_usd) * 10000",
      "bps_per_day": "bps_captured_net / days_held",
      "realized_vs_expected_apr": "realized_apr / target_apr_at_open"
    },
