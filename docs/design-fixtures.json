      "funding_capture":         "realized_apr (format: apr_pct)",
      "dex_cex_arb":             "bps_captured (format: bps)"
    },
    "_render_rules": [
      "All Decimal values are strings. Render with font-mono, tabular-nums.",
      "Sign-prefix all PnL numbers (+ or − using U+2212).",
      "Color +ve in --color-accent-up, -ve in --color-accent-down.",
      "Never display notional. Always display capital_deployed_usd.",
      "Spread name = display label; primary_base = ticker for filter chips."
    ]
  },

