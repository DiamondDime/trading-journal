# ============================================================================
# Journal — environment variables (webapp / self-host mode)
#
# Copy this file to `.env` (or `.env.local` for local Next.js dev) and fill in
# the three required values below: APP_USER_ID, DATABASE_URL, CREDENTIALS_MASTER_KEY.
#
# Desktop users: you don't need to set any of this. The Electron main process
# generates these values on first launch and stores the master key in the OS
# keychain. See ELECTRON.md.
# ============================================================================

# ----- Auth (v1: single-user) -----
# UUID of the single user this instance serves. There is no login UI in v1 —
# every request runs as this user.
# Generate a fresh one with:   uuidgen   (lowercase the output)
# `pnpm db:seed` provisions this UUID with 27 demo activities so the UI isn't
# empty on first install.
APP_USER_ID=00000000-0000-0000-0000-000000000001

# ----- Database -----
# Postgres 16 connection string used by both the Next.js server and the worker.
# Docker default: services reach `postgres` on the internal Docker network.
# Local default: postgresql://$USER@localhost:5432/crypto_spread_journal
DATABASE_URL=postgresql://crypto_journal:replace-me@postgres:5432/crypto_journal

# Password for the postgres container's `crypto_journal` superuser (Docker only).
# Generate with:   openssl rand -base64 24
POSTGRES_PASSWORD=replace-me-with-openssl-rand-base64-24

# ----- Credential encryption -----
# AES-256-GCM master key used to encrypt exchange API keys at rest.
# 32 random bytes, base64-encoded.
# Generate with:   openssl rand -base64 32
# NEVER commit. Back this up out-of-band — losing it bricks every stored API
# key on this instance, and there is no key-versioning in v1.
CREDENTIALS_MASTER_KEY=replace-me-with-openssl-rand-base64-32

# ----- App config -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Screenshot storage -----
# Root directory for journal screenshot uploads. Can be relative (resolved
# against process cwd) or absolute. Files are stored at
#   <SCREENSHOT_STORAGE_DIR>/<userId>/<activityId>/<random-uuid>.<ext>
# Default: ./uploads/screenshots. Add a volume mount in docker-compose for prod.
SCREENSHOT_STORAGE_DIR=./uploads/screenshots

# ----- Worker -----
# How often the worker polls connected exchanges for new fills, in seconds.
# Default 300 (5 minutes). Lower values stress exchange rate limits; higher
# values delay activity ingestion.
WORKER_POLL_INTERVAL_SECONDS=300

# Lookback window for each poll, in days. The worker walks `[now - lookback, now]`
# every cycle and UPSERTs by `raw_exchange_id` so reprocessing the same range is
# safe. 30 days is enough headroom to catch retro-corrected fills without
# hammering pagination.
WORKER_LOOKBACK_DAYS=30

# Worker log level: DEBUG | INFO | WARNING | ERROR. JSON lines on stdout.
WORKER_LOG_LEVEL=INFO

# Cap on the number of exchange syncs running concurrently. Pull this down on
# small hosts; the worker is I/O-bound but each sync holds a Postgres
# transaction.
WORKER_MAX_CONCURRENT_SYNCS=4

# Exchange API rate-limit overrides (optional, for testing only).
# BINANCE_RPS=10
# BYBIT_RPS=10
# HYPERLIQUID_RPS=5
