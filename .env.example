# ============================================================================
# Crypto Spread Journal — environment variables
# Copy to `.env.local` (Next.js) and `worker/.env` (Python worker).
# ============================================================================

# ----- Database -----
# Local Postgres. Worker and Next.js share the same connection string.
DATABASE_URL=postgresql://skywalqr@localhost:5432/crypto_spread_journal

# ----- Auth (v1: single-user) -----
# UUID of the row in public.profiles you want every request to act as.
# Look it up after running `pnpm db:reset` and seeding yourself:
#   psql -d crypto_spread_journal -c "SELECT id, email FROM public.profiles;"
APP_USER_ID=00000000-0000-0000-0000-000000000000

# ----- Credential encryption -----
# AES-256-GCM master key used to encrypt exchange API keys at rest.
# Generate with: openssl rand -base64 32
# NEVER commit. Lose this and all stored API keys become unreadable.
CREDENTIALS_MASTER_KEY=replace-me-with-openssl-rand-base64-32

# ----- App config -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Worker -----
WORKER_LOG_LEVEL=INFO
WORKER_SYNC_INTERVAL_SECONDS=300
WORKER_MAX_CONCURRENT_SYNCS=4

# Exchange API rate-limit overrides (optional, for testing)
# BINANCE_RPS=10
# BYBIT_RPS=10
# HYPERLIQUID_RPS=5
