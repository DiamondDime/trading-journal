# ============================================================================
# Crypto Spread Journal — environment variables
# Copy to `.env.local` (Next.js) and `worker/.env` (Python worker) as appropriate.
# ============================================================================

# ----- Supabase (Next.js + Worker) -----
# Public values (safe in browser):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Secret — Vercel server env only. NOT exposed to browser.
# Required for server actions / API routes that need to call privileged Supabase APIs
# (e.g. creating Vault secrets via security-definer RPCs).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Worker-only (Hetzner). NEVER set on Vercel.
# Connection string for direct Postgres access (worker bypasses PostgREST).
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ----- App config -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Magic-link redirect target after callback
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ----- Worker (Hetzner) -----
WORKER_LOG_LEVEL=INFO
WORKER_SYNC_INTERVAL_SECONDS=300
WORKER_MAX_CONCURRENT_SYNCS=4

# Exchange API rate-limit overrides (optional, for testing)
# BINANCE_RPS=10
# BYBIT_RPS=10
# HYPERLIQUID_RPS=5

# ----- Local dev -----
# When running Supabase locally via `supabase start`, override the above:
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<local anon key from `supabase status`>
# SUPABASE_SERVICE_ROLE_KEY=<local service-role key from `supabase status`>
