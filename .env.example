# ============================================================================
# crypto-journal — environment variables
# Used by both `docker compose up -d` (loads ./.env automatically) and local
# dev (copy to `.env.local` for Next.js, and to `worker/.env` for the worker).
# ============================================================================

# ----- Database -----
# Docker default: web/worker reach postgres on the internal network.
# Local default: postgresql://$USER@localhost:5432/crypto_journal
DATABASE_URL=postgresql://crypto_journal:replace-me@postgres:5432/crypto_journal

# Password for the postgres container's `crypto_journal` superuser.
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=replace-me-with-openssl-rand-base64-24

# ----- Auth (v1: single-user) -----
# Default user for v1 single-user mode. Set to the UUID of your auth.users row.
# `pnpm db:seed` provisions this UUID with 27 demo activities so the UI
# isn't empty on first install.
APP_USER_ID=00000000-0000-0000-0000-000000000001

# ----- Credential encryption -----
# AES-256-GCM master key used to encrypt exchange API keys at rest.
# Generate with: openssl rand -base64 32
# NEVER commit. Lose this and all stored API keys become unreadable.
CREDENTIALS_MASTER_KEY=replace-me-with-openssl-rand-base64-32

# ----- App config -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Screenshot storage (Wave 9A) -----
# Root directory for journal screenshot uploads. Can be relative (resolved
# against process cwd) or absolute. Files are stored at
#   <SCREENSHOT_STORAGE_DIR>/<userId>/<activityId>/<random-uuid>.<ext>
# Default: ./uploads/screenshots. Add a volume mount in docker-compose for prod.
SCREENSHOT_STORAGE_DIR=./uploads/screenshots

# ----- Worker -----
WORKER_LOG_LEVEL=INFO
WORKER_POLL_INTERVAL_SECONDS=300
WORKER_MAX_CONCURRENT_SYNCS=4

# Exchange API rate-limit overrides (optional, for testing)
# BINANCE_RPS=10
# BYBIT_RPS=10
# HYPERLIQUID_RPS=5
